{
  "name": "sistema-fichas-medicas",
  "version": "1.0.0",
  "scripts": {
    "tunnler2windows": "ssh -N -o StrictHostKeyChecking=no -L 127.0.0.1:27018:127.0.0.1:27017 root@31.97.9.216",
    "tunnel": "ssh -fN -o StrictHostKeyChecking=no -L 127.0.0.1:27017:127.0.0.1:27017 root@31.97.9.216",
    "tunnel:windows": "ssh -N -o StrictHostKeyChecking=no -L 127.0.0.1:27017:127.0.0.1:27017 root@31.97.9.216",
    "start:backend": "npm run dev --prefix backend",
    "start:frontend": "npm run start --prefix frontend -- --open --port 4200",
    "dev": "npm run start:backend & npm run start:frontend",
    "dev:windows": "start \"Tunnel\" npm run tunnel:windows && timeout /t 5 && start \"Backend\" npm run start:backend && start \"Frontend\" npm run start:frontend"
  },
  "dependencies": {
    "pm2": "^6.0.6"
  },
  "devDependencies": {
    "typescript": "5.3"
  }
}